<%- include('partials/header', { pageTitle: 'לידים - ' + list.name, page: 'approved', activeListId: list.id, allLists: allLists }) %>

  <%- include('partials/tabbar', { list, page: 'approved' }) %>

  <div class="card" style="margin-bottom:16px;">
    <p style="font-size:13px;color:#888780;margin-top:0;">
      לידים שנכנסו דרך המודעה <b><%= item.subject || ('#' + item.id) %></b>.
      <% if (list.lead_price) { %>מחיר-ייחוס לליד: <%= list.lead_price %> ש"ח (לתזכורת - לא נגבה אוטומטית).<% } %>
    </p>
    <p style="font-size:13px;color:#888780;">
      פרטי המפרסם: <%= item.from_email || '' %><% if (item.phone) { %> · <%= item.phone %><% } %><% if (item.client_name) { %> · <%= item.client_name %><% } %>
    </p>
  </div>

  <% if (leads.length === 0) { %>
    <div class="card">עדיין לא נכנסו לידים למודעה הזו.</div>
  <% } else { %>
    <div class="card">
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="text-align:right;border-bottom:1px solid #e3e1d8;">
            <th style="padding:8px;">שם</th>
            <th style="padding:8px;">טלפון</th>
            <th style="padding:8px;">הערה</th>
            <th style="padding:8px;">תאריך</th>
          </tr>
        </thead>
        <tbody>
          <% leads.forEach(lead => { %>
            <tr style="border-bottom:1px solid #f0efe9;">
              <td style="padding:8px;"><%= lead.name %></td>
              <td style="padding:8px;" dir="ltr"><%= lead.phone %></td>
              <td style="padding:8px;"><%= lead.note || '' %></td>
              <td style="padding:8px;color:#888780;font-size:12px;"><%= lead.created_at %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p style="font-size:13px;color:#888780;margin-top:12px;">סה"כ <%= leads.length %> לידים<% if (list.lead_price) { %> · <%= leads.length * list.lead_price %> ש"ח לחיוב לפי מחיר-הייחוס<% } %></p>
    </div>
  <% } %>

<%- include('partials/footer') %>
