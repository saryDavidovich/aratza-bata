<%- include('partials/header', { pageTitle: 'יומן CallBack', page: 'payment-log', allLists: allLists }) %>

  <div class="pill" style="display:block;margin-bottom:16px;line-height:1.6;max-width:720px;">
    כל בקשת CallBack שהתקבלה מנדרים פלוס. תשלומים אמיתיים מאושרים
    אוטומטית - גם אם ה-IP השולח לא ברשימה המתועדת, המערכת מזהה זאת לפי
    התאמת מזהה העסקה (ראה "auto-confirmed" למטה). שורה עם "rejected" בלי
    התאמה כזו כנראה לא תשלום אמיתי - אבל אם אתם בטוחים שכן, אפשר לבדוק
    ולאשר ידנית כגיבוי אחרון.
  </div>

  <% if (logs.length === 0) { %>
    <div class="card">עדיין לא התקבלה אף בקשת CallBack.</div>
  <% } %>

  <% logs.forEach(log => { %>
    <div class="card" style="margin-bottom:10px;<%= log.trusted ? '' : 'border:1px solid #eadfc0;background:#fdf8ee;' %>">
      <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;font-size:13px;">
        <div>
          <b><%= log.received_at_display %></b>
          - IP: <code><%= log.source_ip %></code>
          <%= log.trusted ? '<span style="color:#0f6e56;">✓ מוכר</span>' : '<span style="color:#c04828;">✗ לא ברשימה המתועדת</span>' %>
        </div>
        <div style="color:#888780;"><%= log.outcome %></div>
      </div>
      <% if (log.item_id) { %>
        <div style="font-size:13px;margin-top:6px;">
          מודעה #<%= log.item_id %> - <%= log.item_email %>
          <% if (log.item_subject) { %>- "<%= log.item_subject %>"<% } %>
          (<%= log.paid_tier === 'premium' ? 'פרימיום' : 'מודגשת' %>)
          - סטטוס תשלום נוכחי: <b><%= log.item_payment_status %></b>
        </div>
        <% if (log.item_payment_status !== 'paid') { %>
          <div style="margin-top:8px;">
            <a class="btn" style="font-size:12px;padding:6px 10px;" href="/admin/items/<%= log.item_id %>/verify-payment">בדוק ואשר ידנית</a>
          </div>
        <% } %>
      <% } %>
      <details style="margin-top:8px;">
        <summary style="cursor:pointer;font-size:12px;color:#888780;">הצג נתונים גולמיים</summary>
        <pre style="font-size:11px;background:#f6f5f1;padding:8px;border-radius:6px;overflow:auto;direction:ltr;text-align:left;"><%= log.raw_body %></pre>
      </details>
    </div>
  <% }) %>

<%- include('partials/footer') %>
