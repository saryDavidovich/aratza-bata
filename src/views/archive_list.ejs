<!DOCTYPE html>
<html dir="rtl" lang="he">
<head><meta charset="utf-8"><title>ארכיון - <%= list.name %></title>
<style>
  body { font-family: Arial, sans-serif; background:#f6f5f1; direction:rtl; margin:0; }
  .wrap { max-width:520px; margin:40px auto; background:#fff; border:1px solid #e3e1d8; border-radius:10px; padding:24px; }
  h1 { font-size:20px; color:#2c2c2a; }
  .issue-row {
    display:flex; justify-content:space-between; align-items:center;
    padding:12px 0; border-bottom:1px solid #eceae3; font-size:14px; color:#5f5e5a;
  }
  .issue-row a { color:<%= list.accent_color %>; text-decoration:none; font-weight:600; }
  .empty { color:#888780; font-size:14px; }
</style>
</head>
<body>
<div class="wrap">
  <span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:<%= list.accent_color %>;margin-bottom:8px;"></span>
  <h1>ארכיון גיליונות - <%= list.name %></h1>

  <% if (issues.length === 0) { %>
    <p class="empty">עדיין לא יצא גיליון לרשימה זו.</p>
  <% } %>

  <% issues.forEach(issue => { %>
    <div class="issue-row">
      <span>גיליון מתאריך <%= issue.sent_at_display %></span>
      <a href="/archive/<%= list.slug %>/<%= issue.id %>" target="_blank">לצפייה &larr;</a>
    </div>
  <% }) %>
</div>
</body>
</html>
